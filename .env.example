# Frontend configuration. Keep all provider secrets server-side below.

VITE_APP_NAME=Dzhero
VITE_API_URL=/api
# The default local profile uses frontend 5173 and backend 3000.
# For the isolated Build Week profile used in the demo:
# VITE_API_URL=http://127.0.0.1:3100/api

# Backend / Instagram Login
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
DB_PATH=backend/data/db.json
# If DATABASE_URL is set, backend stores the MVP app state in Postgres JSONB.
# If empty, backend keeps using DB_PATH JSON storage for local/dev mode.
DATABASE_URL=
DATABASE_SSL=false
APP_STATE_KEY=main
UNLIMITED_ACCESS_EMAILS=
ALLOW_DEMO_LOGIN=false
SESSION_TTL_DAYS=30
MAX_ACTIVE_SESSIONS_PER_USER=8
PAYMENT_CARD_NUMBER=
PAYMENT_CARD_HOLDER=
PAYMENT_CARD_URL=
PAYMENT_SUPPORT_URL=
PAYMENT_NOTE_PREFIX=Dzhero
# Public beta keeps checkout disabled even when payment details are configured.
ENABLE_BILLING_PURCHASES=false
CLIENT_URL=http://127.0.0.1:5173
# Build Week local profile: CLIENT_URL=http://127.0.0.1:5180
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback/google
GOOGLE_SCOPES=openid email profile
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://127.0.0.1:3000/api/auth/instagram/callback
INSTAGRAM_AUTH_BASE_URL=https://www.instagram.com/oauth/authorize
INSTAGRAM_TOKEN_URL=https://api.instagram.com/oauth/access_token
INSTAGRAM_GRAPH_BASE_URL=https://graph.instagram.com
INSTAGRAM_SCOPES=instagram_business_basic,instagram_business_manage_comments,instagram_business_manage_messages,instagram_business_content_publish

# Optional fallback / legacy Facebook Login for Instagram Graph API.
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://127.0.0.1:3000/api/auth/meta/callback
META_AUTH_BASE_URL=https://www.facebook.com/v20.0/dialog/oauth
META_GRAPH_BASE_URL=https://graph.facebook.com/v20.0
META_LOGIN_CONFIG_ID=
# Keep empty for a Login Configuration based flow, or set only scopes approved in the Meta app.
META_SCOPES=

# Security / abuse controls
# Set in production for admin-only routes such as /api/schema and tester grants.
ADMIN_TOKEN=
REGISTER_RATE_LIMIT_PER_HOUR=10
# Optional future CAPTCHA wiring for public forms.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
PUBLIC_PREVIEW_DAILY_LIMIT=10
PUBLIC_PREVIEW_GLOBAL_DAILY_LIMIT=20

# Optional AI providers for remix/scoring generation.
# If empty, backend uses deterministic MVP fallback logic.
OPENAI_API_KEY=
OPENAI_AGENT_MODEL=gpt-5.6
ENABLE_AGENT_STUDIO=false
AGENT_STUDIO_MAX_TURNS=12
AGENT_STUDIO_TIMEOUT_MS=90000
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_REMIX_MODEL=gemini-3.5-flash
GEMINI_VISION_MODEL=gemini-3.5-flash
GEMINI_VIDEO_MODEL=gemini-3.5-flash

# Optional public source APIs.
# Used for YouTube Shorts/channel metadata instead of basic page preview.
YOUTUBE_API_KEY=
APIFY_TOKEN=
AUTOMATIC_DISCOVERY_ENABLED=true
AUTOMATIC_DISCOVERY_TICK_MS=60000
# Free Trial reads this workspace's existing Signals without copying them or invoking Apify.
# Prefer the stable workspace id; owner email is a convenient fallback that picks that user's largest bank.
SHARED_SIGNAL_BANK_WORKSPACE_ID=
SHARED_SIGNAL_BANK_OWNER_EMAIL=
SHARED_SIGNAL_BANK_LIMIT=250
# Keep public Brand Scan on public metadata + Gemini during beta.
ENABLE_PUBLIC_APIFY_BRAND_SCAN=false
# Test-only provider override for automatic discovery API checks (ignored unless NODE_ENV=test)
# AUTOMATIC_DISCOVERY_TEST_PROVIDER=

# TikTok Login Kit
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://127.0.0.1:3000/api/auth/tiktok/callback
TIKTOK_AUTH_BASE_URL=https://www.tiktok.com/v2/auth/authorize/
TIKTOK_TOKEN_URL=https://open.tiktokapis.com/v2/oauth/token/
TIKTOK_USERINFO_URL=https://open.tiktokapis.com/v2/user/info/
TIKTOK_SCOPES=user.info.basic,user.info.profile,user.info.stats
